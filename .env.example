# Global
APP_ENV=local
LOG_LEVEL=info
HTTP_PORT=8080

# API / worker
API_PORT=8080
WORKER_CONCURRENCY=4
QUEUE_NAME=default
JWT_SECRET=replace-with-a-strong-random-secret
ENCRYPTION_KEY=replace-with-32-byte-key

# Database (Postgres)
POSTGRES_USER=app_user
POSTGRES_PASSWORD=replace-with-secure-password
POSTGRES_DB=app_db
DATABASE_URL=postgresql://app_user:replace-with-secure-password@postgres:5432/app_db

# Redis
REDIS_URL=redis://redis:6379/0

# Third-party integrations
OPENAI_API_KEY=sk-...
STRIPE_SECRET_KEY=sk_live_or_test_...
SENTRY_DSN=https://example@sentry.io/project-id
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=app-bucket-name

# Monitoring (optional)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-secure-password
PROMETHEUS_SCRAPE_INTERVAL=15s
